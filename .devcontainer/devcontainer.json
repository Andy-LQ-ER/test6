{
    "name": "Python Dev",
    "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bullseye",

    // Add Node.js (required for Claude Code CLI)
    "features": {
        "ghcr.io/devcontainers/features/node:1": {
            "version": "lts"
        }
    },

    // Mount host ~/.claude so auth & config carry over automatically
    "mounts": [
        "source=${localEnv:USERPROFILE}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached"
    ],

    // Install uv, then sync deps + install pre-commit hooks + Claude Code CLI
    "onCreateCommand": "pip install uv",
    "postCreateCommand": "uv sync --all-groups && uv run pre-commit install && npm install -g @anthropic-ai/claude-code",

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "charliermarsh.ruff",
                "ms-python.mypy-type-checker",
                "tamasfe.even-better-toml",
                "github.vscode-github-actions",
                "anthropic.claude-code"
            ],
            "settings": {
                // Point VS Code at the uv-managed venv
                "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python",

                // Format + fix imports on save via Ruff
                "editor.formatOnSave": true,
                "[python]": {
                    "editor.defaultFormatter": "charliermarsh.ruff",
                    "editor.codeActionsOnSave": {
                        "source.fixAll.ruff": "explicit",
                        "source.organizeImports.ruff": "explicit"
                    }
                },

                // mypy daemon for faster type checks
                "mypy-type-checker.preferDaemon": true
            }
        }
    },

    "remoteUser": "vscode"
}
